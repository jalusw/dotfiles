syntax on                     " Enable syntax highlighting

set nocompatible              
set backspace=indent,eol,start  
set relativenumber
set hlsearch                  
set incsearch                 
set ignorecase                
set smartcase                 
set tabstop=2                 
set shiftwidth=2              
set expandtab                 
set autoindent                
set mouse=a                   
set laststatus=2              
set wrap                      
set linebreak                 
set cursorline                

